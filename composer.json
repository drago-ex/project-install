{
	"name": "drago-ex/project-install",
	"type": "drago-project-resource",
	"description": "Application installation package.",
	"license": ["MIT"],
	"require": {
		"php": ">=8.3 <9",
		"drago-ex/bootstrap": "dev-master as  1.9999",
		"drago-ex/translator": "dev-master as  2.9999",
		"drago-ex/project-permission": "dev-main as 1.999",
		"drago-ex/permission": "dev-main as 1.9999",
		"drago-ex/datagrid": "dev-main as 1.9999",
		"drago-ex/migration": "@dev",
		"drago-ex/utils": "dev-master as 1.999",
		"drago-ex/application": "dev-master as 1.999",
		"drago-ex/component": "dev-main as 1.999",
		"drago-ex/form": "dev-main as 1.999",
		"drago-ex/database": "dev-master as 2.9999",
		"drago-ex/project-auth": "dev-main as 1.999",
		"drago-ex/project-settings": "dev-main as 1.999"
	},
	"autoload": {
		"classmap": ["src/"]
	},
	"extra": {
		"drago-project": {
			"allow-library-install": true,
			"install": {
				"copy": {
					"resources/app/install": "app/install",
					"resources/assets": "assets"
				},
				"replace": {
					"resources/bootstrap.php": "app",
					"resources/www": "www"
				}
			}
		}
	},
	"require-dev": {
		"phpstan/phpstan-nette": "^2.0",
		"drago-ex/project-installer": "@dev"
	},
	"scripts": {
		"phpstan": "phpstan analyse",
		"post-install-cmd": [
			"drago-install --dev",
			"drago-clean"
		],
		"post-update-cmd": [
			"drago-install --dev",
			"drago-clean"
		]
	}
}
