{
	"name": "drago-ex/project-install",
	"type": "drago-project-resource",
	"description": "Application installation package.",
	"license": ["MIT"],
	"require": {
		"php": ">=8.3 <9",
		"drago-ex/bootstrap": "^2.0",
		"drago-ex/translator": "^3.0",
		"drago-ex/project-permission": "dev-main",
		"drago-ex/permission": "^2.0",
		"drago-ex/datagrid": "dev-main",
		"drago-ex/migration": "^2.0",
		"drago-ex/utils": "^2.0",
		"drago-ex/application": "^2.0",
		"drago-ex/component": "^2.0",
		"drago-ex/form": "^2.0",
		"drago-ex/database": "^3.0",
		"drago-ex/project-auth": "^2.0",
		"drago-ex/project-settings": "^1.0"
	},
	"autoload": {
		"classmap": ["src/"]
	},
	"extra": {
		"drago-project": {
			"skip": false,
			"allow-library-install": true,
			"install": {
				"copy": {
					"resources/app/Install": "app/Install",
					"resources/assets": "assets"
				},
				"replace": {
					"resources/app/Bootstrap.php": "app",
					"resources/app/app.neon": "app",
					"resources/www": "www"
				}
			}
		}
	},
	"require-dev": {
		"phpstan/phpstan-nette": "^2.0",
		"drago-ex/project-installer": "@dev"
	},
	"scripts": {
		"phpstan": "phpstan analyse",
		"post-install-cmd": [
			"drago-install --dev",
			"drago-clean"
		],
		"post-update-cmd": [
			"drago-install --dev",
			"drago-clean"
		]
	}
}
