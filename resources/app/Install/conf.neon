services:

	# cache for install steps
	install.cache: {class: Nette\Caching\Cache, arguments: [@Nette\Caching\IStorage, 'Install.CacheSteps'], autowired: no}

	- App\Install\Steps(@install.cache)
	- Nette\DI\Config\Adapters\NeonAdapter

	# database migrations
	- App\Install\MigrationService(migrationsPath: %appDir%/../migrations)
	- App\Install\Factory\DatabaseFactory(configPath: %appDir%)
	- App\UI\Backend\Sign\Factory
	- App\UI\Backend\Sign\SignUpFactory
	- App\Install\InstallPresenter(tempPath: %tempDir%)


routing:
    routes:
        '[<lang=cs cs|en>/]<presenter>/': Install:default


# application settings
application:
	scanDirs: false

	# application mapping
	mapping: App\*\**Presenter


# application extensions
extensions:
	translator: Drago\Localization\DI\TranslatorExtension(%appDir%, %tempDir%)


# automatic class registration
search:
	-
		in: %appDir%/Install/Factory
		classes:
			- *Factory
			- *Control
			- *Repository


# nette asset building
assets:
	mapping:
		default:
			path: dist
			type: vite
